<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="monthly_clinic_report"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="782" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail">

    <parameter name="CLINIC_NAME" class="java.lang.String">
        <defaultValueExpression><![CDATA["City Clinic"]]></defaultValueExpression>
    </parameter>

    <queryString>
        <![CDATA[
            SELECT
                a.appointment_id,
                CONCAT(p.first_name, ' ', p.last_name)       AS patient_name,
                CONCAT('Dr. ', d.first_name, ' ', d.last_name) AS doctor_name,
                d.specialization,
                a.appointment_date,
                a.appointment_time,
                a.status,
                a.reason,
                diag.diagnosis,
                diag.prescription,
                COALESCE(pay.amount, 0)                       AS amount,
                pay.payment_method,
                pay.status                                    AS payment_status
            FROM appointments a
            JOIN patients p  ON a.patient_id = p.patient_id
            JOIN doctors  d  ON a.doctor_id  = d.doctor_id
            LEFT JOIN diagnoses diag ON a.appointment_id = diag.appointment_id
            LEFT JOIN payments  pay  ON a.appointment_id = pay.appointment_id
            ORDER BY a.appointment_date DESC, d.last_name
        ]]>
    </queryString>

    <field name="appointment_id"   class="java.lang.Integer"/>
    <field name="patient_name"     class="java.lang.String"/>
    <field name="doctor_name"      class="java.lang.String"/>
    <field name="specialization"   class="java.lang.String"/>
    <field name="appointment_date" class="java.sql.Date"/>
    <field name="appointment_time" class="java.sql.Time"/>
    <field name="status"           class="java.lang.String"/>
    <field name="reason"           class="java.lang.String"/>
    <field name="diagnosis"        class="java.lang.String"/>
    <field name="prescription"     class="java.lang.String"/>
    <field name="amount"           class="java.math.BigDecimal"/>
    <field name="payment_method"   class="java.lang.String"/>
    <field name="payment_status"   class="java.lang.String"/>

    <variable name="totalRevenue" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
        <initialValueExpression><![CDATA[new java.math.BigDecimal("0")]]></initialValueExpression>
    </variable>
    <variable name="totalAppointments" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{appointment_id}]]></variableExpression>
    </variable>

    <!-- TITLE BAND -->
    <title>
        <band height="70">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="70" backcolor="#1E3C72"/>
            </rectangle>
            <staticText>
                <reportElement x="0" y="5" width="782" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[MONTHLY CLINIC ACTIVITY REPORT]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="38" width="782" height="20" forecolor="#AADDFF"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="12"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CLINIC_NAME} + " | Generated: " + new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm").format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- COLUMN HEADER -->
    <columnHeader>
        <band height="28">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="28" backcolor="#2C3E50"/>
            </rectangle>
            <staticText><reportElement x="0"   y="4" width="30"  height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[ID]]></text></staticText>
            <staticText><reportElement x="30"  y="4" width="100" height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Patient Name]]></text></staticText>
            <staticText><reportElement x="130" y="4" width="110" height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Doctor]]></text></staticText>
            <staticText><reportElement x="240" y="4" width="80"  height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Date]]></text></staticText>
            <staticText><reportElement x="320" y="4" width="60"  height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText>
            <staticText><reportElement x="380" y="4" width="130" height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Diagnosis]]></text></staticText>
            <staticText><reportElement x="510" y="4" width="80"  height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Amount (LKR)]]></text></staticText>
            <staticText><reportElement x="590" y="4" width="80"  height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Pay Method]]></text></staticText>
            <staticText><reportElement x="670" y="4" width="80"  height="20" forecolor="#FFFFFF"/><textElement><font fontName="Arial" size="9" isBold="true"/></textElement><text><![CDATA[Pay Status]]></text></staticText>
        </band>
    </columnHeader>

    <!-- DETAIL BAND -->
    <detail>
        <band height="24" splitType="Stretch">
            <textField><reportElement x="0"   y="4" width="30"  height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{appointment_id}]]></textFieldExpression></textField>
            <textField><reportElement x="30"  y="4" width="100" height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{patient_name}]]></textFieldExpression></textField>
            <textField><reportElement x="130" y="4" width="110" height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{doctor_name}]]></textFieldExpression></textField>
            <textField><reportElement x="240" y="4" width="80"  height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{appointment_date}]]></textFieldExpression></textField>
            <textField><reportElement x="320" y="4" width="60"  height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="380" y="4" width="130" height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{diagnosis}]]></textFieldExpression></textField>
            <textField><reportElement x="510" y="4" width="80"  height="16"/><textElement textAlignment="Right"><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{amount})]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="590" y="4" width="80"  height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{payment_method}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="670" y="4" width="80"  height="16"/><textElement><font fontName="Arial" size="9"/></textElement><textFieldExpression><![CDATA[$F{payment_status}]]></textFieldExpression></textField>
        </band>
    </detail>

    <!-- SUMMARY BAND -->
    <summary>
        <band height="60">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="60" backcolor="#ECF0F1"/>
            </rectangle>
            <staticText>
                <reportElement x="10" y="8" width="200" height="20"/>
                <textElement><font fontName="Arial" size="11" isBold="true"/></textElement>
                <text><![CDATA[SUMMARY]]></text>
            </staticText>
            <staticText><reportElement x="10" y="30" width="150" height="18"/><textElement><font fontName="Arial" size="10" isBold="true"/></textElement><text><![CDATA[Total Appointments:]]></text></staticText>
            <textField><reportElement x="165" y="30" width="80" height="18"/><textElement><font fontName="Arial" size="10"/></textElement><textFieldExpression><![CDATA[$V{totalAppointments}]]></textFieldExpression></textField>
            <staticText><reportElement x="300" y="30" width="150" height="18"/><textElement><font fontName="Arial" size="10" isBold="true"/></textElement><text><![CDATA[Total Revenue (LKR):]]></text></staticText>
            <textField>
                <reportElement x="455" y="30" width="120" height="18"/>
                <textElement textAlignment="Right"><font fontName="Arial" size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($V{totalRevenue})]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
